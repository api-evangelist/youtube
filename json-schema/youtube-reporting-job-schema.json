  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The server-generated ID of the job.",
      "example": "abc123def456"
    },
    "reportTypeId": {
      "type": "string",
      "description": "The type of reports that the job creates.",
      "example": "500123"
    },
    "name": {
